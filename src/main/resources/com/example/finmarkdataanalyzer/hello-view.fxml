<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finmarkdataanalyzer.HelloController">

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="loadDataBtn" text="Load Stock Data" />
        <Button fx:id="runModelBtn" text="Run Analysis" />
        <Button fx:id="resetBtn" text="Reset Dashboard" />
    </HBox>

    <Label fx:id="metricsLabel" text="AI Confidence Metrics will appear here..." style="-fx-text-fill: #AAAAAA; -fx-font-weight: bold; -fx-font-size: 14px;" />

    <TableView fx:id="dataTable" prefHeight="250.0" VBox.vgrow="ALWAYS" />

    <LineChart fx:id="stockChart" title="Stock Trend and Predictions" VBox.vgrow="ALWAYS">
        <xAxis>
            <CategoryAxis label="Date" side="BOTTOM" />
        </xAxis>
        <yAxis>
            <NumberAxis label="Price" side="LEFT" />
        </yAxis>
    </LineChart>

</VBox>